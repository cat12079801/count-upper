# E2E テスト用の環境変数。`.env.e2e` にコピーして使う（.env.e2e は .gitignore 済み）。
# ローカル Supabase (`supabase start`) の出力値を設定する。

# `supabase status` の API URL / anon key
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status の anon key>

# Playwright の baseURL（webServer の起動ポートに合わせる）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# テスト専用サインイン経路（/auth/test-login）を有効化する。本番には絶対設定しない。
E2E_TEST_LOGIN=true
E2E_TEST_EMAIL=e2e@example.com
E2E_TEST_PASSWORD=e2e-password-123
